# ============================================================
# Telemedicine Booking Platform — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================

# --- Database (MongoDB Atlas) ---
# Get from: https://cloud.mongodb.com → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/telemedicine?retryWrites=true&w=majority

# --- Authentication ---
# Generate a strong random secret: openssl rand -base64 32
JWT_SECRET=your-very-long-random-secret-here

# --- Admin ---
ADMIN_PASSWORD=your-admin-password
ADMIN_EMAIL=your-gmail@gmail.com
ADMIN_URL=https://your-project.vercel.app/en/admin

# --- Email (Resend) ---
# Get from: https://resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@yourdomain.com

# --- Forms (Formspree) --- Phase 1
# Get from: https://formspree.io → Forms → Form ID
NEXT_PUBLIC_FORMSPREE_ID=your-formspree-form-id

# --- CMS (Contentful) --- Phase 3
# Get from: https://app.contentful.com → Settings → API Keys
CONTENTFUL_SPACE_ID=your-space-id
CONTENTFUL_ACCESS_TOKEN=your-content-delivery-api-token
CONTENTFUL_PREVIEW_TOKEN=your-content-preview-api-token

# --- App ---
# Development: http://localhost:3000
# Production: https://your-project.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Feature Flags (optional) ---
# Set to 'true' to enable Phase 2/3 features during development
NEXT_PUBLIC_ENABLE_AUTH=false
NEXT_PUBLIC_ENABLE_CMS=false
NEXT_PUBLIC_ENABLE_VIDEO=false
